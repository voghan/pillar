<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="sling:Mapping">
  <cards-mapping-single
    jcr:primaryType="nt:unstructured"
    sling:match="content/pillar/us/en/cards/([^/.]+)\.html"
    sling:internalRedirect="/content/pillar/us/en/cards/detail.$1.html"/>
  <cards-mapping-double
      jcr:primaryType="nt:unstructured"
      sling:match="content/pillar/us/en/cards/([^/.]+)/([^/.]+)\.html"
      sling:internalRedirect="/content/pillar/us/en/cards/detail.$1.$2.html"/>
  <cards-mapping-triple
    jcr:primaryType="nt:unstructured"
    sling:match="content/pillar/us/en/cards/([^/.]+)/([^/.]+)/([^/.]+)\.html"
    sling:internalRedirect="/content/pillar/us/en/cards/detail.$1.$2.$3.html"/>
  <articles-mapping
    jcr:primaryType="nt:unstructured"
    sling:match="content/pillar/us/en/articles/([^/.]+)\.html"
    sling:internalRedirect="/content/pillar/us/en/articles/detail.$1.html"/>
</jcr:root>
